# Credential material for the FeatureDoc backend — TEMPLATE.
#
# This is an .example file, deliberately NOT applied by `kubectl apply -f
# deploy/k8s/` (which ignores non-YAML extensions). The kind/CI e2e applies it
# explicitly (see scripts/e2e.sh) because the app there runs in mock mode
# (GITHUB_MODE/LLM_MODE=mock) and never contacts GitHub or any LLM provider, so
# these placeholder values are non-secret.
#
# For staging/production: copy to secret.yaml (gitignored) or create the
# Secret out-of-band from the real GitHub App credentials and a freshly
# generated 32-byte KEK. Do NOT commit real values.
apiVersion: v1
kind: Secret
metadata:
  name: featuredoc-credentials
  labels:
    app.kubernetes.io/name: featuredoc
type: Opaque
stringData:
  # 32-byte key-encryption key, base64-encoded (envelope encryption KEK).
  CREDENTIALS_KEK: "MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY="
  # GitHub App user-authorization + app credentials (unused in mock mode).
  # The client_id is also the JWT issuer for app auth — no separate App ID.
  GITHUB_APP_SLUG: "featuredoc"
  GITHUB_CLIENT_ID: "Iv1.placeholderclientid"
  GITHUB_CLIENT_SECRET: "placeholder-client-secret"
  GITHUB_APP_PRIVATE_KEY: ""
