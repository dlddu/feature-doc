# featuredoc-secrets — template for the credentials the app reads via envFrom.
#
# This *.example file is committed; the filled-in copy is not. To deploy:
#
#   cp deploy/k8s/secret.yaml.example deploy/k8s/secret.yaml
#   # edit deploy/k8s/secret.yaml with real values
#   kubectl apply -k deploy/k8s              # deployment + service + pvc
#   kubectl apply -f deploy/k8s/secret.yaml  # the Secret (provisioned separately)
#
# deploy/k8s/secret.yaml is gitignored so real credentials are never committed.
# Non-secret config (FEATUREDOC_MODE, BASE_URL, COOKIE_SECURE, DATABASE_URL) is
# plain env on the Deployment, not here. The e2e overlay generates its own
# stub-mode secret, so this file is for real deployments only.
apiVersion: v1
kind: Secret
metadata:
  name: featuredoc-secrets
  labels:
    app.kubernetes.io/name: featuredoc
type: Opaque
stringData:
  # 32+ bytes of randomness — the KEK that wraps every per-record DEK.
  FEATUREDOC_KEK: "replace-with-a-random-32-byte-secret"
  # FeatureDoc GitHub App: user-authorization client id (also the App JWT issuer),
  # client secret, App slug (for the install URL), and the App private key (PEM).
  GITHUB_CLIENT_ID: ""
  GITHUB_CLIENT_SECRET: ""
  GITHUB_APP_SLUG: "featuredoc"
  GITHUB_APP_PRIVATE_KEY: |
    -----BEGIN RSA PRIVATE KEY-----
    ...replace with the App's private key...
    -----END RSA PRIVATE KEY-----
